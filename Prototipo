<script>
/* ══════════════════════════════════════════════════
   DATA — Registros iniciales de demostración
══════════════════════════════════════════════════ */
let records = [
  {
    id: 1, lab: 'Laboratorios BioFarma S.A.', labId: 'LAB-001',
    reps: 4, carta: true,
    facturado: true, tipoFactura: 'PPD', folioFactura: 'FAC-2025-08',
    pagado: false, fechaPago: '', folioRep: '',
    cancelado: false
  },
  {
    id: 2, lab: 'MedPharm Distribuciones', labId: 'LAB-002',
    reps: 2, carta: true,
    facturado: true, tipoFactura: 'PUE', folioFactura: 'FAC-2025-14',
    pagado: true, fechaPago: '05/06/2025', folioRep: 'REP-2025-22',
    cancelado: false
  },
  {
    id: 3, lab: 'Farmasalud del Norte', labId: 'LAB-003',
    reps: 6, carta: false,
    facturado: false, tipoFactura: '', folioFactura: '',
    pagado: false, fechaPago: '', folioRep: '',
    cancelado: false
  },
  {
    id: 4, lab: 'Instituto Químico Mexicano', labId: 'LAB-004',
    reps: 3, carta: true,
    facturado: false, tipoFactura: '', folioFactura: '',
    pagado: false, fechaPago: '', folioRep: '',
    cancelado: false
  },
  {
    id: 5, lab: 'Distribuidora Clínica Oriente', labId: 'LAB-005',
    reps: 1, carta: true,
    facturado: true, tipoFactura: 'PUE', folioFactura: 'FAC-2025-07',
    pagado: true, fechaPago: '12/05/2025', folioRep: 'REP-2025-19',
    cancelado: false
  },
  {
    id: 6, lab: 'GenTech Biotecnología', labId: 'LAB-006',
    reps: 2, carta: false,
    facturado: false, tipoFactura: '', folioFactura: '',
    pagado: false, fechaPago: '', folioRep: '',
    cancelado: true
  }
];

let nextId = 7;
let currentRole = 'admin'; // 'admin' | 'rep'
let editingId = null;
let modalMode = 'new'; // 'new' | 'edit' | 'detail'

/* ══════════════════════════════════════════════════
   HELPERS
══════════════════════════════════════════════════ */
function getStatus(r) {
  if (r.cancelado) return 'cancelado';
  const done = [r.carta, r.facturado, r.pagado].filter(Boolean).length;
  if (done === 3) return 'completo';
  if (done > 0) return 'progreso';
  return 'ninguno';
}

function statusBadge(r) {
  const s = getStatus(r);
  const map = {
    completo:  ['badge-green', '✓ Completo'],
    progreso:  ['badge-amber', '◑ En progreso'],
    cancelado: ['badge-red',   '✕ Cancelado'],
    ninguno:   ['badge-gray',  '○ Sin iniciar'],
  };
  const [cls, label] = map[s];
  return `<span class="badge ${cls}"><span class="dot"></span>${label}</span>`;
}

function rowClass(r) {
  const map = { completo: 'row-complete', progreso: 'row-progress', cancelado: 'row-cancelled', ninguno: 'row-none' };
  return map[getStatus(r)];
}

function yesNo(val, yesLabel='Sí', noLabel='—') {
  return val
    ? `<span style="color:var(--green);font-weight:600;">${yesLabel}</span>`
    : `<span style="color:var(--muted);">${noLabel}</span>`;
}

function updateStats() {
  document.getElementById('stat-total').textContent = records.length;
  document.getElementById('stat-completos').textContent = records.filter(r => getStatus(r) === 'completo').length;
  document.getElementById('stat-progreso').textContent = records.filter(r => getStatus(r) === 'progreso').length;
  document.getElementById('stat-pendientes').textContent = records.filter(r => getStatus(r) === 'ninguno').length;
}

/* ══════════════════════════════════════════════════
   RENDER TABLA (RF-08)
══════════════════════════════════════════════════ */
function renderTabla() {
  const q = document.getElementById('filter-search').value.toLowerCase();
  const fs = document.getElementById('filter-status').value;
  const fc = document.getElementById('filter-carta').value;
  const ff = document.getElementById('filter-factura').value;

  let filtered = records.filter(r => {
    if (q && !r.lab.toLowerCase().includes(q) && !r.labId.toLowerCase().includes(q) && !r.folioFactura.toLowerCase().includes(q)) return false;
    if (fs && getStatus(r) !== fs) return false;
    if (fc === 'si' && !r.carta) return false;
    if (fc === 'no' && r.carta) return false;
    if (ff === 'si' && !r.facturado) return false;
    if (ff === 'no' && r.facturado) return false;
    return true;
  });

  const tbody = document.getElementById('tabla-body');
  const empty = document.getElementById('tabla-empty');

  if (!filtered.length) {
    tbody.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';

  tbody.innerHTML = filtered.map(r => `
    <tr class="${rowClass(r)}" onclick="openModal('detail', ${r.id})">
      <td>
        <div class="lab-name">${r.lab}</div>
        <div class="lab-id">${r.labId}</div>
      </td>
      <td><strong>${r.reps}</strong> rep${r.reps !== 1 ? 's' : ''}.</td>
      <td>${yesNo(r.carta, 'Enviada', 'No enviada')}</td>
      <td>${r.tipoFactura ? `<span class="pill-tag" style="background:var(--accent-lt);color:var(--accent);">${r.tipoFactura}</span>` : '<span style="color:var(--muted)">—</span>'}</td>
      <td style="font-family:var(--font-mono);font-size:12px;">${r.folioFactura || '<span style="color:var(--muted)">—</span>'}</td>
      <td>${yesNo(r.pagado, r.fechaPago || 'Sí', 'Pendiente')}</td>
      <td style="font-family:var(--font-mono);font-size:12px;">${r.folioRep || '<span style="color:var(--muted)">—</span>'}</td>
      <td>${statusBadge(r)}</td>
      <td>
        <button class="btn btn-ghost" style="padding:4px 8px;font-size:12px;" onclick="event.stopPropagation();openModal('edit',${r.id})">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Editar
        </button>
      </td>
    </tr>
  `).join('');

  updateStats();
}

/* ══════════════════════════════════════════════════
   BÚSQUEDA (RF-07, RF-01)
══════════════════════════════════════════════════ */
function buscar() {
  const q = document.getElementById('busqueda-input').value.toLowerCase().trim();
  const container = document.getElementById('busqueda-results');
  if (!q) { container.innerHTML = ''; return; }

  const found = records.filter(r =>
    r.lab.toLowerCase().includes(q) ||
    r.labId.toLowerCase().includes(q) ||
    r.folioFactura.toLowerCase().includes(q)
  );

  if (!found.length) {
    container.innerHTML = `<div class="empty-state" style="padding:32px 0;"><h3>Sin resultados</h3><p>No se encontró ningún registro con ese término.</p></div>`;
    return;
  }

  container.innerHTML = found.map(r => `
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;margin-bottom:10px;cursor:pointer;" onclick="openModal('detail',${r.id})">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;">
        <div>
          <div style="font-weight:700;font-size:14px;">${r.lab}</div>
          <div style="font-size:11px;color:var(--muted);font-family:var(--font-mono);">${r.labId} · ${r.reps} representante${r.reps !== 1 ? 's' : ''}</div>
        </div>
        ${statusBadge(r)}
      </div>
      <div style="display:flex;gap:16px;margin-top:10px;font-size:12px;">
        <span>Carta: ${r.carta ? '✅ Enviada' : '❌ Pendiente'}</span>
        <span>Factura: ${r.facturado ? `✅ ${r.tipoFactura} ${r.folioFactura}` : '❌ Sin factura'}</span>
        <span>Pago: ${r.pagado ? `✅ ${r.fechaPago}` : '❌ Pendiente'}</span>
      </div>
    </div>
  `).join('');
}

/* ══════════════════════════════════════════════════
   MODAL (RF-04, RF-05, RF-06, RF-09, RF-10)
══════════════════════════════════════════════════ */
function openModal(mode, id) {
  modalMode = mode;
  editingId = id || null;
  const bg = document.getElementById('modal-bg');
  bg.classList.add('open');

  const saveBtn = document.getElementById('modal-save-btn');

  if (mode === 'nuevo' || mode === 'new') {
    document.getElementById('modal-title').textContent = 'Nuevo laboratorio';
    document.getElementById('modal-subtitle').textContent = 'Completa los campos disponibles. Puedes guardar con información parcial.';
    saveBtn.textContent = 'Crear registro';
    saveBtn.style.display = '';
    renderForm(null);
  } else if (mode === 'edit') {
    const r = records.find(x => x.id === id);
    document.getElementById('modal-title').textContent = r.lab;
    document.getElementById('modal-subtitle').textContent = `Editar registro — ${r.labId}`;
    saveBtn.textContent = 'Guardar cambios';
    saveBtn.style.display = '';
    renderForm(r);
  } else { // detail / RF-10
    const r = records.find(x => x.id === id);
    document.getElementById('modal-title').textContent = r.lab;
    document.getElementById('modal-subtitle').textContent = `Vista detalle — ${r.labId}`;
    saveBtn.style.display = 'none';
    renderDetail(r);
  }
}

function renderDetail(r) {
  document.getElementById('modal-body').innerHTML = `
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
      ${statusBadge(r)}
      <span style="font-size:12px;color:var(--muted);">Actualiza el registro con el botón Editar</span>
    </div>

    <div class="section-title">Datos del laboratorio</div>
    <div class="form-grid" style="margin-bottom:0;">
      <div><div style="font-size:11px;color:var(--muted);font-weight:600;margin-bottom:2px;">LABORATORIO</div><div>${r.lab}</div></div>
      <div><div style="font-size:11px;color:var(--muted);font-weight:600;margin-bottom:2px;">ID</div><div style="font-family:var(--font-mono);">${r.labId}</div></div>
    </div>
    <div style="margin:12px 0 20px;"><div style="font-size:11px;color:var(--muted);font-weight:600;margin-bottom:2px;">N.° DE REPRESENTANTES</div><div style="font-size:20px;font-weight:700;">${r.reps}</div></div>

    <div class="section-title">Proceso</div>
    <div class="rep-card-body" style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
      <div class="rep-step ${r.carta?'done':'pending'}">
        <div class="rep-step-label">Carta invitación</div>
        <div class="rep-step-status">${r.carta ? '✅ Enviada' : '—'}</div>
      </div>
      <div class="rep-step ${r.facturado?'done':'pending'}">
        <div class="rep-step-label">Facturación</div>
        <div class="rep-step-status">${r.facturado ? '✅ Facturado' : '—'}</div>
        ${r.folioFactura ? `<div style="font-size:11px;color:var(--muted);">${r.tipoFactura} · ${r.folioFactura}</div>` : ''}
      </div>
      <div class="rep-step ${r.pagado?'done':'pending'}">
        <div class="rep-step-label">Pago</div>
        <div class="rep-step-status">${r.pagado ? '✅ Registrado' : '—'}</div>
        ${r.pagado ? `<div style="font-size:11px;color:var(--muted);">${r.fechaPago} · ${r.folioRep}</div>` : ''}
      </div>
    </div>

    <div class="divider" style="margin-top:20px;"></div>
    <div style="display:flex;justify-content:flex-end;margin-top:0;">
      <button class="btn btn-primary" onclick="openModal('edit',${r.id})">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Editar registro
      </button>
    </div>
  `;
}

function renderForm(r) {
  const v = r || { id: null, lab: '', labId: '', reps: '', carta: false, facturado: false, tipoFactura: '', folioFactura: '', pagado: false, fechaPago: '', folioRep: '', cancelado: false };
  document.getElementById('modal-body').innerHTML = `
    <div class="section-title">Datos del laboratorio</div>
    <div class="form-grid">
      <div class="form-group">
        <label>Nombre del laboratorio <span class="req">*</span></label>
        <input class="form-input" id="f-lab" value="${v.lab}" placeholder="Laboratorios Ejemplo S.A.">
      </div>
      <div class="form-group">
        <label>ID de laboratorio <span class="req">*</span></label>
        <input class="form-input" id="f-labId" value="${v.labId}" placeholder="LAB-001">
      </div>
      <div class="form-group">
        <label>N.° de representantes <span class="req">*</span><br><span class="form-hint">Sólo enteros positivos (≥ 1)</span></label>
        <input class="form-input" id="f-reps" type="number" min="1" value="${v.reps}" placeholder="1">
        <span class="field-error" id="err-reps" style="display:none;">Ingresa un número entero mayor a 0.</span>
      </div>
      <div class="form-group" style="justify-content:flex-end;padding-bottom:6px;">
        <label>Estado de cancelación</label>
        <div class="toggle-wrap">
          <label class="toggle"><input type="checkbox" id="f-cancelado" ${v.cancelado?'checked':''}><span class="slider"></span></label>
          <span class="toggle-label" id="label-cancelado">${v.cancelado ? 'Cancelado' : 'Activo'}</span>
        </div>
      </div>
    </div>

    <div class="section-title">Carta invitación (RF-03)</div>
    <div class="form-grid">
      <div class="form-group">
        <label>¿Carta enviada?</label>
        <div class="toggle-wrap" style="margin-top:4px;">
          <label class="toggle"><input type="checkbox" id="f-carta" ${v.carta?'checked':''}><span class="slider"></span></label>
          <span class="toggle-label" id="label-carta">${v.carta ? 'Sí, enviada' : 'No enviada'}</span>
        </div>
      </div>
    </div>

    <div class="section-title">Facturación (RF-04)</div>
    <div class="form-grid cols-3">
      <div class="form-group">
        <label>¿Facturado?</label>
        <div class="toggle-wrap" style="margin-top:4px;">
          <label class="toggle"><input type="checkbox" id="f-facturado" ${v.facturado?'checked':''} onchange="toggleFactura()"><span class="slider"></span></label>
          <span class="toggle-label" id="label-facturado">${v.facturado ? 'Facturado' : 'Sin factura'}</span>
        </div>
      </div>
      <div class="form-group" id="grp-tipo">
        <label>Tipo de factura</label>
        <select class="form-select" id="f-tipoFactura">
          <option value="">Seleccionar</option>
          <option value="PUE" ${v.tipoFactura==='PUE'?'selected':''}>PUE</option>
          <option value="PPD" ${v.tipoFactura==='PPD'?'selected':''}>PPD</option>
        </select>
        <span class="form-hint">Solo PUE o PPD son válidos.</span>
      </div>
      <div class="form-group" id="grp-folio">
        <label>Folio de facturación</label>
        <input class="form-input" id="f-folioFactura" value="${v.folioFactura}" placeholder="FAC-2025-01" maxlength="20">
        <span class="form-hint">Máx. 20 caracteres alfanuméricos.</span>
      </div>
    </div>

    <div class="section-title">Pago (RF-05)</div>
    <div id="aviso-pago-req" style="${v.facturado?'display:none':'display:block'};padding:10px 14px;background:var(--amber-lt);border-radius:var(--radius);margin-bottom:14px;font-size:12px;color:var(--amber);">
      ⚠️ Debes registrar la factura antes de poder registrar el pago.
    </div>
    <div class="form-grid cols-3" id="grp-pago">
      <div class="form-group">
        <label>¿Pago realizado?</label>
        <div class="toggle-wrap" style="margin-top:4px;">
          <label class="toggle"><input type="checkbox" id="f-pagado" ${v.pagado?'checked':''} ${!v.facturado?'disabled':''}><span class="slider"></span></label>
          <span class="toggle-label">${v.pagado ? 'Pagado' : 'Pendiente'}</span>
        </div>
      </div>
      <div class="form-group">
        <label>Fecha de pago <span class="form-hint">(DD/MM/AAAA)</span></label>
        <input class="form-input" id="f-fechaPago" value="${v.fechaPago}" placeholder="15/06/2025" ${!v.facturado?'disabled':''}>
      </div>
      <div class="form-group">
        <label>Folio REP (complemento)</label>
        <input class="form-input" id="f-folioRep" value="${v.folioRep}" placeholder="REP-2025-01" ${!v.facturado?'disabled':''}>
        <span class="form-hint">Debe ser único en el sistema.</span>
        <span class="field-error" id="err-rep" style="display:none;">Este folio REP ya existe en otro registro.</span>
      </div>
    </div>
  `;
  // Wire dynamic label updates
  document.getElementById('f-cancelado').onchange = e => { document.getElementById('label-cancelado').textContent = e.target.checked ? 'Cancelado' : 'Activo'; };
  document.getElementById('f-carta').onchange = e => { document.getElementById('label-carta').textContent = e.target.checked ? 'Sí, enviada' : 'No enviada'; };
  document.getElementById('f-facturado').onchange = e => { document.getElementById('label-facturado').textContent = e.target.checked ? 'Facturado' : 'Sin factura'; toggleFactura(); };
}

function toggleFactura() {
  const has = document.getElementById('f-facturado').checked;
  document.getElementById('aviso-pago-req').style.display = has ? 'none' : 'block';
  document.getElementById('f-pagado').disabled = !has;
  document.getElementById('f-fechaPago').disabled = !has;
  document.getElementById('f-folioRep').disabled = !has;
}

function saveRecord() {
  // Validations (RF-02 / RF-04 / RF-05)
  let valid = true;

  // Validate reps
  const reps = parseInt(document.getElementById('f-reps').value);
  if (isNaN(reps) || reps < 1) {
    document.getElementById('err-reps').style.display = 'block';
    document.getElementById('f-reps').classList.add('error');
    valid = false;
  } else {
    document.getElementById('err-reps').style.display = 'none';
    document.getElementById('f-reps').classList.remove('error');
  }

  // Validate folio REP duplicate (RF-05)
  const folioRepVal = document.getElementById('f-folioRep').value.trim();
  if (folioRepVal) {
    const dup = records.find(r => r.folioRep === folioRepVal && r.id !== editingId);
    if (dup) {
      document.getElementById('err-rep').style.display = 'block';
      document.getElementById('f-folioRep').classList.add('error');
      valid = false;
    } else {
      document.getElementById('err-rep').style.display = 'none';
      document.getElementById('f-folioRep').classList.remove('error');
    }
  }

  if (!valid) { showToast('Corrige los errores antes de guardar.', 'error'); return; }

  const data = {
    lab:          document.getElementById('f-lab').value.trim() || 'Sin nombre',
    labId:        document.getElementById('f-labId').value.trim() || `LAB-${String(nextId).padStart(3,'0')}`,
    reps:         reps,
    carta:        document.getElementById('f-carta').checked,
    facturado:    document.getElementById('f-facturado').checked,
    tipoFactura:  document.getElementById('f-tipoFactura').value,
    folioFactura: document.getElementById('f-folioFactura').value.trim(),
    pagado:       document.getElementById('f-pagado').checked,
    fechaPago:    document.getElementById('f-fechaPago').value.trim(),
    folioRep:     folioRepVal,
    cancelado:    document.getElementById('f-cancelado').checked,
  };

  if (modalMode === 'edit') {
    const idx = records.findIndex(r => r.id === editingId);
    records[idx] = { ...records[idx], ...data };
    showToast('Registro actualizado correctamente.', 'success');
  } else {
    records.push({ id: nextId++, ...data });
    showToast('Nuevo laboratorio registrado.', 'success');
  }

  closeModal();
  renderTabla();
}

function closeModal() { document.getElementById('modal-bg').classList.remove('open'); }
function closeModalOnBg(e) { if (e.target === document.getElementById('modal-bg')) closeModal(); }

/* ══════════════════════════════════════════════════
   TOAST
══════════════════════════════════════════════════ */
function showToast(msg, type='info') {
  const c = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${
    type==='success' ? '<path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>' :
    type==='error'   ? '<circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/>' :
    '<circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>'
  }</svg>${msg}`;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3200);
}

/* ══════════════════════════════════════════════════
   SCREENS & NAV
══════════════════════════════════════════════════ */
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
  const s = document.getElementById(`screen-${name}`);
  if (s) s.classList.add('active');
  const n = document.getElementById(`nav-${name === 'mi-proceso' ? 'mi-proceso' : name}`);
  if (n) n.classList.add('active');
  const titles = { reporte: 'Reporte de Laboratorios', busqueda: 'Consulta Rápida', 'mi-proceso': 'Mi Proceso de Credencialización' };
  document.getElementById('topbar-title').textContent = titles[name] || '';
  if (name === 'busqueda') document.getElementById('busqueda-input').focus();
}

/* ══════════════════════════════════════════════════
   LOGIN (RNF-02, RF-12)
══════════════════════════════════════════════════ */
let selectedRole = 'admin';
function selectRole(r) {
  selectedRole = r;
  document.getElementById('pill-admin').classList.toggle('selected', r === 'admin');
  document.getElementById('pill-rep').classList.toggle('selected', r === 'rep');
}

function doLogin() {
  const u = document.getElementById('login-user').value.trim();
  const p = document.getElementById('login-pass').value;
  // RNF-02: min 8 chars, 1 uppercase, 1 number
  const passOk = p.length >= 8 && /[A-Z]/.test(p) && /[0-9]/.test(p);
  if (!u || !passOk) {
    showToast('Contraseña debe tener mínimo 8 caracteres, una mayúscula y un número.', 'error');
    return;
  }
  currentRole = selectedRole;
  document.getElementById('screen-login').classList.remove('active');
  document.getElementById('app-shell').style.display = 'flex';

  // Role-based UI (RF-12, RF-13)
  const isRep = currentRole === 'rep';
  document.getElementById('sidebar-username').textContent = u;
  document.getElementById('sidebar-role').textContent = isRep ? '🩺 Representante Médico' : '👤 Administrador';
  document.getElementById('btn-nuevo').style.display = isRep ? 'none' : '';
  document.getElementById('nav-section-rep').style.display = isRep ? 'block' : 'none';
  document.getElementById('nav-mi-proceso').style.display = isRep ? 'flex' : 'none';

  if (isRep) {
    // Rep only sees their own process
    document.getElementById('nav-reporte').style.display = 'none';
    document.getElementById('nav-busqueda').style.display = 'none';
    showScreen('mi-proceso');
  } else {
    renderTabla();
    showScreen('reporte');
  }
  showToast(`Bienvenido/a, ${u.split('@')[0]}.`, 'success');
}

function doLogout() {
  document.getElementById('app-shell').style.display = 'none';
  document.getElementById('screen-login').classList.add('active');
  // Reset nav for re-login
  document.getElementById('nav-reporte').style.display = '';
  document.getElementById('nav-busqueda').style.display = '';
}

// Init
renderTabla();
</script>
</body>
</html>
