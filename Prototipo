<body>

<!-- ══════════════════════════════════════════════════════════
     LOGIN SCREEN (RNF-02, RF-12)
══════════════════════════════════════════════════════════ -->
<div id="screen-login" class="active">
  <div class="login-card">
    <div class="login-logo">
      <div class="lmark">Sistema de Gestión</div>
      <div class="lname">CredencialMed</div>
    </div>
    <div class="login-title">Iniciar sesión</div>
    <div class="login-sub">Accede con tu cuenta asignada por la administradora.</div>

    <div style="margin-bottom:14px;">
      <div style="font-size:12px;font-weight:600;margin-bottom:6px;">Tipo de cuenta</div>
      <div class="login-role">
        <div class="role-pill selected" id="pill-admin" onclick="selectRole('admin')">👤 Administrador</div>
        <div class="role-pill" id="pill-rep" onclick="selectRole('rep')">🩺 Representante</div>
      </div>
    </div>

    <div class="login-group">
      <label>Usuario</label>
      <input type="text" id="login-user" placeholder="ej. supervisora@empresa.com" value="admin@hospital.mx">
    </div>
    <div class="login-group">
      <label>Contraseña <span style="font-size:11px;color:var(--muted);font-weight:400;">(mín. 8 caracteres, 1 mayúscula, 1 número)</span></label>
      <input type="password" id="login-pass" placeholder="Contraseña" value="Admin123">
    </div>
    <button class="login-btn" onclick="doLogin()">Entrar</button>
    <div class="login-hint">⚠️ Prototipo — cualquier contraseña válida funciona para demostración.</div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════
     APP SHELL
══════════════════════════════════════════════════════════ -->
<div class="app" id="app-shell" style="display:none;">

  <!-- Sidebar -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <span class="logo-mark">Sistema de Gestión</span>
      <span class="logo-name">CredencialMed</span>
    </div>
    <div class="sidebar-nav">
      <div class="nav-section">Principal</div>
      <button class="nav-item active" id="nav-reporte" onclick="showScreen('reporte')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        Reporte General
      </button>
      <button class="nav-item" id="nav-busqueda" onclick="showScreen('busqueda')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        Buscar Laboratorio
      </button>
      <div class="nav-section" id="nav-section-rep" style="display:none;">Mi Seguimiento</div>
      <button class="nav-item" id="nav-mi-proceso" style="display:none;" onclick="showScreen('mi-proceso')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        Mi Proceso
      </button>
    </div>
    <div class="sidebar-footer">
      <span class="user-name" id="sidebar-username">Cargando…</span>
      <span id="sidebar-role">—</span>
      <br><a href="#" onclick="doLogout()" style="color:rgba(255,255,255,.4);font-size:11px;margin-top:4px;display:inline-block;">Cerrar sesión</a>
    </div>
  </nav>

  <!-- Main -->
  <div class="main">

    <!-- Topbar -->
    <header class="topbar">
      <div class="topbar-left">
        <span class="topbar-title" id="topbar-title">Reporte de Laboratorios</span>
        <span class="badge badge-blue" id="topbar-badge" style="font-size:11px;">Ciclo 2025</span>
      </div>
      <div class="topbar-right">
        <button class="btn btn-secondary" onclick="showScreen('busqueda')">
